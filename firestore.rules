rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Admins collection: Authenticated users ONLY (CRUD)
    match /admins/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Orders collection: Authenticated users ONLY (CRUD)
    match /orders/{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Products collection (including subcollections like variants):
    // Public read, but authenticated write (Create, Update, Delete)
    match /products/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

  }
}
